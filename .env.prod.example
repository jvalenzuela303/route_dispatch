# ============================================
# Claude Logistics API - Production Environment
# ============================================
#
# IMPORTANT: Copy this file to .env.prod and fill in the values
# DO NOT commit .env.prod to version control!
#
# Generate secure secrets with:
#   openssl rand -hex 32
#   openssl rand -base64 32

# ============================================
# Database Configuration
# ============================================
DB_USER=claude_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://claude_admin:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/route_dispatch

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_HERE@redis:6379/0

# ============================================
# JWT & Security
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY_HERE_64_CHARS_MIN
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE=30
JWT_REFRESH_EXPIRE=7

# ============================================
# SMTP / Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@botilleria.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD_HERE
SMTP_FROM_EMAIL=noreply@botilleria.com
SMTP_USE_TLS=true

# ============================================
# Application Configuration
# ============================================
LOG_LEVEL=INFO
ENVIRONMENT=production
CORS_ORIGINS=https://botilleria.com,https://www.botilleria.com,https://admin.botilleria.com

# ============================================
# Geocoding Service
# ============================================
NOMINATIM_USER_AGENT=ClaudeLogistics/1.0 (+https://botilleria.com)

# ============================================
# Uvicorn Workers
# ============================================
# Recommended: (2 x CPU cores) + 1
# For 2 CPU cores: 5 workers
# For 4 CPU cores: 9 workers
UVICORN_WORKERS=4

# ============================================
# Docker Build
# ============================================
VERSION=1.0.0
BUILD_DATE=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# ============================================
# Domain Configuration (for SSL)
# ============================================
DOMAIN=botilleria.com
EMAIL_ADMIN=admin@botilleria.com
